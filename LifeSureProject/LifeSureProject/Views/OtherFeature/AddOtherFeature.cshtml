@model LifeSureProject.Models.DataModels.TblOtherFeature

@{
    ViewBag.Title = "Add Other Feature";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="w-full max-w-3xl">

    <div class="mb-6">
        <h1 class="text-2xl font-semibold text-gray-800">Yeni Diğer Özellik</h1>
        <p class="text-sm text-gray-500 mt-1">Başlık, açıklama ve ikon bilgilerini gir.</p>
    </div>

    @using (Html.BeginForm("AddOtherFeature", "OtherFeature", FormMethod.Post))
    {
        <div class="rounded-xl border border-gray-200 bg-white shadow-sm p-6 space-y-5">

            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">Başlık</label>
                @Html.TextBoxFor(x => x.OtherFeatureTitle, new { @class = "w-full rounded-lg border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-cyan-500", placeholder = "Örn: 7/24 Destek" })
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">Açıklama</label>
                @Html.TextAreaFor(x => x.OtherFeatureDescription, 5, 0, new { @class = "w-full rounded-lg border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-cyan-500", placeholder = "Kısa açıklama..." })
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">İkon Class</label>
                @Html.TextBoxFor(x => x.OtherFeatureIcon, new { @class = "w-full rounded-lg border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-cyan-500", placeholder = "Örn: fa-solid fa-shield-halved" })
                <p class="text-xs text-gray-500 mt-2">
                    FontAwesome kullanıyorsan: <span class="font-mono">fa-solid fa-star</span> gibi.
                </p>
            </div>

            <div class="flex items-center justify-end gap-2 pt-2">
                <a href="@Url.Action("OtherFeatureList","OtherFeature")"
                   class="rounded-lg border border-gray-200 bg-white px-4 py-2.5 text-sm font-semibold text-gray-700 hover:bg-gray-50 transition">
                    Vazgeç
                </a>

                <button type="submit"
                        class="rounded-lg bg-cyan-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-cyan-700 transition">
                    Kaydet
                </button>
            </div>

        </div>
    }

</div>