@model List<LifeSureProject.Models.DataModels.TblFeature>

@{
    ViewBag.Title = "Feature List";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="w-full max-w-none">

    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6 gap-3">
        <div>
            <h1 class="text-2xl font-semibold text-gray-800">Öne Çıkanlar</h1>
            <p class="text-sm text-gray-500 mt-1">
                Özellikleri görüntüleyebilir veya silebilirsin.
            </p>
        </div>

        <a href="/Feature/AddFeature"
           class="inline-flex items-center gap-2 rounded-lg bg-cyan-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-cyan-700 transition">
            <i class="fa-solid fa-plus"></i>
            Yeni Özellik
        </a>
    </div>

    <div class="rounded-xl border border-gray-200 bg-white shadow-sm overflow-hidden">

        <div class="overflow-x-auto">

            <table class="min-w-full w-full">

                <thead class="bg-gray-50 border-b border-gray-200">

                    <tr>
                        <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-5 py-3">
                            ID
                        </th>

                        <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-5 py-3">
                            Başlık
                        </th>

                        <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-5 py-3">
                            Açıklama
                        </th>

                        <th class="text-right text-xs font-semibold text-gray-500 uppercase tracking-wider px-5 py-3">
                            İşlemler
                        </th>
                    </tr>

                </thead>

                <tbody class="divide-y divide-gray-200">

                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="px-5 py-10 text-center text-sm text-gray-500">
                                Henüz özellik eklenmemiş.
                            </td>
                        </tr>
                    }

                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr class="hover:bg-gray-50 transition">

                                <td class="px-5 py-4 text-sm text-gray-700">
                                    @item.FeatureId
                                </td>

                                <td class="px-5 py-4 text-sm font-semibold text-gray-900">
                                    @item.FeatureTitle
                                </td>

                                <td class="px-5 py-4 text-sm text-gray-600">
                                    @{
                                        var desc = item.FeatureDescription ?? "";
                                        var shortDesc = desc.Length > 150 ? desc.Substring(0, 150) + "..." : desc;
                                    }
                                    @shortDesc
                                </td>

                                <td class="px-5 py-4 text-right">

                                    <a href="/Feature/DeleteFeature/@item.FeatureId"
                                       onclick="return confirm('Bu özelliği silmek istediğine emin misin?');"
                                       class="inline-flex items-center gap-2 rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm font-semibold text-rose-700 hover:bg-rose-100 transition">

                                        <i class="fa-regular fa-trash-can"></i>
                                        Sil

                                    </a>

                                </td>

                            </tr>
                        }
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>