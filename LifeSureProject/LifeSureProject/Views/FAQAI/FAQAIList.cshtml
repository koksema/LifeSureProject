@model List<LifeSureProject.Models.DataModels.TblQuestion>
@{
    ViewBag.Title = "AI SSS Listesi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int count = 0;
}

<div class="p-4 bg-white block sm:flex items-center justify-between border-b border-gray-200 lg:mt-1.5">
    <div class="mb-1 w-full">
        <div class="mb-4">
            <nav class="flex mb-5" aria-label="Breadcrumb">
                <ol class="inline-flex items-center space-x-1 md:space-x-2">
                    <li class="inline-flex items-center">
                        <a href="#" class="text-gray-700 hover:text-cyan-600 inline-flex items-center">
                            <i class="fa fa-home mr-2.5"></i> Admin
                        </a>
                    </li>
                    <li>
                        <div class="flex items-center">
                            <i class="fa fa-chevron-right text-gray-400 text-sm mx-2"></i>
                            <span class="text-gray-400 ml-1 md:ml-2 font-medium">AI Soru Listesi</span>
                        </div>
                    </li>
                </ol>
            </nav>
            <h1 class="text-xl sm:text-2xl font-semibold text-gray-900">Yapay Zeka ile Oluşturulan SSS Listesi</h1>
        </div>
        <div class="sm:flex">
            <div class="flex items-center space-x-2 sm:space-x-3 ml-auto">
                <a href="/FAQAI/GenerateAI" class="text-white bg-cyan-600 hover:bg-cyan-700 focus:ring-4 focus:ring-cyan-200 font-medium inline-flex items-center rounded-lg text-sm px-5 py-2.5 text-center">
                    <i class="fa fa-plus mr-2"></i> Yeni AI Sorusu Oluştur
                </a>
            </div>
        </div>
    </div>
</div>

<div class="flex flex-col my-6 mx-4">
    <div class="overflow-x-auto shadow-lg rounded-lg">
        <div class="inline-block min-w-full align-middle">
            <div class="overflow-hidden bg-white">
                @if (!Model.Any())
                {
                    <div class="p-10 text-center">
                        <i class="fa-regular fa-face-frown text-gray-300 text-6xl mb-4"></i>
                        <p class="text-gray-500 text-lg">Henüz hiçbir AI sorusu oluşturulmamış.</p>
                        <a href="/FAQAI/GenerateAI" class="text-cyan-600 font-medium hover:underline">Hemen bir tane oluşturun &rarr;</a>
                    </div>
                }
                else
                {
                    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 p-6 bg-gray-50">
                        @foreach (var item in Model)
                        {
                            count++;
                            <div class="bg-white border border-gray-200 rounded-2xl p-5 shadow-sm hover:shadow-md transition-shadow relative overflow-hidden flex flex-col h-full">
                                <div class="absolute top-0 right-0 bg-cyan-50 text-cyan-600 px-3 py-1 rounded-bl-xl font-bold text-xs">
                                    #@count
                                </div>

                                <div class="mb-3">
                                    <span class="text-[10px] font-bold uppercase tracking-wider text-cyan-500 mb-1 block">KONU BAŞLIĞI</span>
                                    <h3 class="text-gray-800 font-bold text-lg leading-tight">@item.QuestionTitle</h3>
                                </div>

                                <hr class="border-gray-100 mb-4" />

                                <div class="mb-4">
                                    <div class="flex items-start gap-2">
                                        <span class="bg-orange-100 text-orange-600 rounded-lg p-1 text-[10px] font-black mt-1">S</span>
                                        <p class="text-gray-700 font-medium text-sm italic">"@item.Question"</p>
                                    </div>
                                </div>

                                <div class="mb-6 flex-grow">
                                    <div class="flex items-start gap-2">
                                        <span class="bg-green-100 text-green-600 rounded-lg p-1 text-[10px] font-black mt-1">C</span>
                                        <p class="text-gray-500 text-sm leading-relaxed">@item.QuestionAnswer</p>
                                    </div>
                                </div>

                                <div class="flex items-center justify-between pt-4 border-t border-gray-50 mt-auto">
                                    <div class="flex space-x-2">
                                        <a href="#" class="text-white bg-cyan-600 hover:bg-cyan-700 focus:ring-4 focus:ring-cyan-200 font-medium rounded-lg text-xs px-3 py-2 text-center inline-flex items-center">
                                            <i class="fa fa-edit mr-1"></i> Düzenle
                                        </a>
                                        <a href="#" onclick="return confirm('Bu kaydı silmek istediğinize emin misiniz?')" class="text-red-700 bg-red-50 hover:bg-red-100 focus:ring-4 focus:ring-red-200 font-medium rounded-lg text-xs px-3 py-2 text-center inline-flex items-center">
                                            <i class="fa fa-trash-alt mr-1"></i> Sil
                                        </a>
                                    </div>
                                    <span class="text-[10px] text-gray-400 font-medium italic">LifeSure AI</span>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />