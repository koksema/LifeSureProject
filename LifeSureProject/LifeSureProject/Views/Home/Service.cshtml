@model List<LifeSureProject.Models.DataModels.TblService>
<div class="container-fluid service py-5">
    <div class="container py-5">
        <div class="text-center mx-auto pb-5 wow fadeInUp" data-wow-delay="0.2s" style="max-width: 800px;">
            <h1 class="display-4 mb-4">Size En İyi Hizmetleri Sunuyoruz</h1>
            <p class="mb-0">
                “Müşterilerimizin ihtiyaçlarına uygun, güvenilir ve kapsamlı sigorta hizmetleri sunuyoruz. Sağlık, araç, ev ve yaşam sigortası gibi farklı alanlarda sunduğumuz çözümlerle hem sizi hem de sevdiklerinizi hayatın beklenmedik risklerine karşı güvence altına alıyoruz.”
            </p>
        </div>
        <div class="row g-4 justify-content-center">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-6 col-xl-3 wow fadeInUp" data-wow-delay="0.2s">
                    <div class="service-item">
                        <div class="service-img">
                            <img src="@item.ServiceImg" class="img-fluid rounded-top w-100" alt="">
                            <div class="service-icon p-3">
                                <i class="@item.ServiceIcon"></i>
                            </div>
                        </div>
                        <div class="service-content p-4">
                            <div class="service-content-inner">
                                <a href="#" class="d-inline-block h4 mb-4">@item.ServiceTitle</a>

                            </div>
                        </div>
                    </div>
                </div>
            }
            <div class="col-12 text-center wow fadeInUp" data-wow-delay="0.2s">
                <a class="btn btn-primary rounded-pill py-3 px-5" href="#">Daha Fazla Hizmet</a>
            </div>
        </div>
    </div>
</div>

