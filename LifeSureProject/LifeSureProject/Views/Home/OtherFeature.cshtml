@model List<LifeSureProject.Models.DataModels.TblOtherFeature>

<div class="container-fluid feature bg-light py-5">
    <div class="container py-5">
        <div class="text-center mx-auto pb-5 wow fadeInUp" data-wow-delay="0.2s" style="max-width: 800px;">
            <h4 class="text-primary">@Resources.SharedResource.OurFeatures</h4>
            <h1 class="display-4 mb-4">@Resources.SharedResource.OurFeaturesTitle</h1>
            <p class="mb-0">
                “LifeSure olarak müşterilerimize güvenilir, esnek ve hızlı sigorta hizmetleri sunuyoruz. 7/24 destek, kişiselleştirilebilir planlar ve müşteri memnuniyetini ön planda tutan hizmet anlayışımızla her zaman yanınızdayız.”
            </p>
        </div>



        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-6 col-xl-3 wow fadeInUp" data-wow-delay="0.2s">
                    <div class="feature-item p-4 pt-0">
                        <div class="feature-icon p-4 mb-4">
                            <i class="@item.OtherFeatureIcon"></i>
                        </div>
                        <h4 class="mb-4">@item.OtherFeatureTitle</h4>
                        <p class="mb-4">
                            @item.OtherFeatureDescription
                        </p>
                        <a class="btn btn-primary rounded-pill py-2 px-4" href="#">Learn More</a>
                    </div>
                </div>
            }
        </div>

    </div>
</div>