@model List<LifeSureProject.Models.DataModels.TblTestimonial>

@{
    ViewBag.Title = "Referanslarımız";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="w-full">

    <div class="flex justify-between items-center mb-6">
        <div>
            <h1 class="text-2xl font-semibold text-gray-800">Referanslarımız</h1>
            <p class="text-sm text-gray-500">Referansları görüntüleyebilir, güncelleyebilir veya silebilirsin.</p>
        </div>

        <a href="@Url.Action("AddTestimonial","Testimonial")"
           class="bg-cyan-600 text-white px-4 py-2 rounded-lg text-sm hover:bg-cyan-700 flex items-center gap-2">
            <i class="fa-solid fa-plus"></i>
            Yeni Referans
        </a>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">

        <table class="w-full">

            <thead class="bg-gray-50 border-b">
                <tr>
                    <th class="text-left px-5 py-3 text-xs text-gray-500 uppercase">ID</th>
                    <th class="text-left px-5 py-3 text-xs text-gray-500 uppercase">Görsel</th>
                    <th class="text-left px-5 py-3 text-xs text-gray-500 uppercase">İsim</th>
                    <th class="text-left px-5 py-3 text-xs text-gray-500 uppercase">Unvan</th>
                    <th class="text-left px-5 py-3 text-xs text-gray-500 uppercase">Açıklama</th>
                    <th class="text-right px-5 py-3 text-xs text-gray-500 uppercase">İşlemler</th>
                </tr>
            </thead>

            <tbody class="divide-y">

                @foreach (var item in Model)
                {
                    <tr class="hover:bg-gray-50">

                        <td class="px-5 py-4">@item.TestimonialId</td>

                        <td class="px-5 py-4">
                            <img src="@item.TestimonialImgUrl"
                                 class="w-12 h-12 rounded-full object-cover border" />
                        </td>

                        <td class="px-5 py-4 font-medium">
                            @item.TestimonialName
                        </td>

                        <td class="px-5 py-4 text-gray-600">
                            @item.TestimonialTitle
                        </td>

                        <td class="px-5 py-4 text-gray-600">
                            @{
                                var text = item.TestimonialDescription ?? "";
                                var shortText = text.Length > 120 ? text.Substring(0, 120) + "..." : text;
                            }
                            @shortText
                        </td>

                        <td class="px-5 py-4 text-right">

                            <a href="@Url.Action("UpdateTestimonial","Testimonial", new { id = item.TestimonialId })"
                               class="border px-3 py-2 rounded-lg text-sm hover:bg-gray-50 mr-2">
                                <i class="fa-regular fa-pen-to-square"></i>
                                Düzenle
                            </a>

                            <a href="@Url.Action("DeleteTestimonial","Testimonial", new { id = item.TestimonialId })"
                               onclick="return confirm('Silmek istediğine emin misin?');"
                               class="border border-red-200 bg-red-50 text-red-600 px-3 py-2 rounded-lg text-sm hover:bg-red-100">
                                <i class="fa-regular fa-trash-can"></i>
                                Sil
                            </a>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>