@model LifeSureProject.Models.ViewModels.ServicesAIViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid pt-4 px-4" style="font-family:'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;">
    <div class="row g-4">
        <div class="col-12">

            <div style="
                border-radius: 18px;
                overflow: hidden;
                box-shadow: 0 20px 50px rgba(0,0,0,0.10);
                background: linear-gradient(135deg, #0ea5e9 0%, #22c55e 100%);
                padding: 2px;
            ">
                <div style="background:#fff;border-radius:16px;overflow:hidden;">

                    <!-- HEADER -->
                    <div style="
                        padding: 26px 28px;
                        background: radial-gradient(circle at top left, rgba(14,165,233,0.15), rgba(34,197,94,0.10), transparent 60%),
                                    linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
                        border-bottom: 1px solid #eef2f7;
                    ">
                        <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;">
                            <div>
                                <h3 style="margin:0;color:#0f172a;font-weight:800;letter-spacing:-0.3px;">
                                    ✨ AI Hizmet Tasarım Merkezi
                                </h3>
                                <div style="margin-top:6px;color:#64748b;font-size:14px;">
                                    Prompt yaz → görsel üret → <b>sunucuya + veritabanına kaydet</b>.
                                </div>
                            </div>

                            <div style="
                                padding:10px 14px;
                                border-radius:999px;
                                background: linear-gradient(90deg, rgba(14,165,233,0.12), rgba(34,197,94,0.12));
                                color:#0f172a;
                                font-weight:700;
                                font-size:13px;
                                border: 1px solid rgba(15,23,42,0.06);
                            ">
                                🛡️ LifeSure • Admin
                            </div>
                        </div>
                    </div>

                    <!-- ALERTS -->
                    <div style="padding:18px 28px 0 28px;">
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div style="
                                border-radius: 12px;
                                padding: 14px 16px;
                                background: linear-gradient(90deg, rgba(239,68,68,0.12), rgba(244,63,94,0.08));
                                border: 1px solid rgba(239,68,68,0.25);
                                color: #7f1d1d;
                                margin-bottom: 14px;
                            ">
                                <div style="font-weight:800;margin-bottom:6px;">⚠️ Hata</div>
                                @Html.ValidationSummary(false)
                            </div>
                        }

                        @if (TempData["Success"] != null)
                        {
                            <div style="
                                border-radius: 12px;
                                padding: 14px 16px;
                                background: linear-gradient(90deg, rgba(34,197,94,0.16), rgba(14,165,233,0.10));
                                border: 1px solid rgba(34,197,94,0.25);
                                color: #064e3b;
                                margin-bottom: 14px;
                                font-weight: 700;
                            ">
                                ✅ @TempData["Success"]
                            </div>
                        }
                    </div>

                    <div class="row g-0">

                        <!-- LEFT / FORM -->
                        <div class="col-md-7" style="padding: 26px 28px 28px 28px; border-right: 1px solid #eef2f7;">

                            @using (Html.BeginForm("GenerateImage", "ServiceAI", FormMethod.Post))
                            {
                                @Html.AntiForgeryToken()
                                @Html.HiddenFor(m => m.ServiceId)

                                <!-- Title -->
                                <div style="margin-bottom:16px;">
                                    <label style="display:block;font-weight:800;margin-bottom:8px;color:#0f172a;">Hizmet Başlığı</label>
                                    @Html.TextBoxFor(m => m.ServicesCardTitle, new
                                    {
                                        @style = @"
                                            width:100%;
                                            padding:12px 14px;
                                            border:1px solid #e5e7eb;
                                            border-radius:12px;
                                            outline:none;
                                            background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
                                            box-shadow: 0 1px 0 rgba(0,0,0,0.02);
                                        ",
                                        placeholder = "Örn: Sağlık Sigortası"
                                    })
                                </div>

                                <!-- Icon -->
                                <div style="margin-bottom:16px;">
                                    <label style="display:block;font-weight:800;margin-bottom:8px;color:#0f172a;">İkon Sınıfı</label>
                                    @Html.TextBoxFor(m => m.ServicesCardIcon, new
                                    {
                                        @style = @"
                                            width:100%;
                                            padding:12px 14px;
                                            border:1px solid #e5e7eb;
                                            border-radius:12px;
                                            outline:none;
                                            background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
                                        ",
                                        placeholder = "Örn: fa fa-shield-alt"
                                    })
                                    <small style="color:#64748b;display:block;margin-top:6px;">
                                        İstersen ikon yerine görseli ana sayfada göstereceğiz.
                                    </small>
                                </div>

                                <!-- Prompt -->
                                <div style="margin-bottom:18px;">
                                    <label style="display:block;font-weight:800;margin-bottom:8px;color:#0f172a;">Görsel Betimlemesi (AI Prompt)</label>
                                    @Html.TextAreaFor(m => m.ServicesCardDescription, new
                                    {
                                        @style = @"
                                            width:100%;
                                            padding:12px 14px;
                                            border:1px solid #e5e7eb;
                                            border-radius:12px;
                                            outline:none;
                                            min-height:120px;
                                            background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
                                        ",
                                        placeholder = "Professional life insurance illustration, modern flat design, clean background, corporate style..."
                                    })

                                    <div style="
                                        margin-top:10px;
                                        padding:10px 12px;
                                        border-radius:12px;
                                        background: linear-gradient(90deg, rgba(14,165,233,0.10), rgba(34,197,94,0.08));
                                        border: 1px solid rgba(15,23,42,0.06);
                                        color:#0f172a;
                                        font-size: 13px;
                                    ">
                                        💡 İpucu: İngilizce yaz, “clean background, modern flat, corporate” ekle.
                                    </div>
                                </div>

                                <!-- Button -->
                                <button type="submit"
                                        style="
                                            width:100%;
                                            padding: 14px 18px;
                                            border: none;
                                            border-radius: 14px;
                                            font-weight: 900;
                                            letter-spacing: .2px;
                                            color: white;
                                            cursor: pointer;
                                            background: linear-gradient(90deg, #0ea5e9 0%, #22c55e 100%);
                                            box-shadow: 0 12px 25px rgba(14,165,233,0.22);
                                            transition: transform .15s ease, box-shadow .15s ease, filter .15s ease;
                                        "
                                        onmouseover="this.style.transform='translateY(-1px)'; this.style.boxShadow='0 16px 30px rgba(34,197,94,0.22)'; this.style.filter='brightness(1.02)';"
                                        onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 12px 25px rgba(14,165,233,0.22)'; this.style.filter='none';"
                                        onmousedown="this.style.transform='translateY(1px)';">
                                    🪄 Görseli Üret ve Sisteme Kaydet
                                </button>

                                if (Model.ServiceId.HasValue && Model.ServiceId.Value > 0)
                                {
                                    <div style="margin-top:10px;color:#64748b;font-size:12px;">
                                        Düzenlenen Hizmet ID: <b>@Model.ServiceId</b>
                                    </div>
                                }
                            }
                        </div>

                        <!-- RIGHT / PREVIEW -->
                        <div class="col-md-5" style="padding: 26px 28px; background: linear-gradient(180deg,#f8fafc 0%, #ffffff 100%);">

                            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
                                <div style="font-weight:900;color:#0f172a;letter-spacing:.6px;text-transform:uppercase;font-size:12px;">
                                    Görsel Önizleme
                                </div>
                                <div style="
                                    font-size:12px;
                                    color:#0f172a;
                                    padding:6px 10px;
                                    border-radius:999px;
                                    background: rgba(14,165,233,0.10);
                                    border: 1px solid rgba(14,165,233,0.18);
                                    font-weight:800;
                                ">
                                    1024×1024
                                </div>
                            </div>

                            <div style="
                                border-radius: 16px;
                                background: #fff;
                                padding: 10px;
                                box-shadow: 0 10px 25px rgba(0,0,0,0.06);
                                border: 1px solid #eef2f7;
                            ">
                                @if (!string.IsNullOrEmpty(Model.ServicesCardImageUrl))
                                {
                                    <img src="@Url.Content(Model.ServicesCardImageUrl)"
                                         alt="AI Generated"
                                         style="
                                            width:100%;
                                            border-radius: 12px;
                                            display:block;
                                            box-shadow: 0 14px 30px rgba(0,0,0,0.10);
                                         " />

                                    <div style="
                                        margin-top: 10px;
                                        padding: 10px 12px;
                                        border-radius: 12px;
                                        background: linear-gradient(90deg, rgba(34,197,94,0.16), rgba(14,165,233,0.10));
                                        border: 1px solid rgba(34,197,94,0.22);
                                        color: #064e3b;
                                        font-weight: 900;
                                        font-size: 13px;
                                        text-align:center;
                                    ">
                                        ✅ Görsel hazır & kaydedildi
                                    </div>
                                }
                                else
                                {
                                    <div style="
                                        height: 280px;
                                        border-radius: 12px;
                                        display:flex;
                                        flex-direction:column;
                                        align-items:center;
                                        justify-content:center;
                                        color:#94a3b8;
                                        background: radial-gradient(circle at 30% 30%, rgba(14,165,233,0.10), transparent 55%),
                                                    radial-gradient(circle at 70% 60%, rgba(34,197,94,0.10), transparent 55%),
                                                    #ffffff;
                                        border: 1px dashed #e2e8f0;
                                    ">
                                        <div style="font-size:70px;line-height:1;">🖼️</div>
                                        <div style="margin-top:10px;font-weight:800;">Henüz görsel üretilmedi</div>
                                        <div style="margin-top:4px;font-size:12px;">Soldan prompt yazıp üret</div>
                                    </div>
                                }
                            </div>

                            <div style="margin-top:14px;color:#64748b;font-size:12px;line-height:1.5;">
                                <b>Örnek Prompt:</b>
                                <div style="margin-top:6px;padding:10px 12px;border-radius:12px;background:#fff;border:1px solid #eef2f7;">
                                    Professional life insurance illustration, modern flat design, clean background, soft blue and white palette, corporate style
                                </div>
                            </div>

                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>