@{
    Layout = null;
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Windster Admin</title>

    <link rel="icon" type="image/svg+xml" href="https://themewagon.github.io/windster/images/logo.svg">

    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
@RenderSection("Scripts", required: false)
<body class="bg-gray-50">

   <nav class="bg-white border-b border-gray-200 fixed z-30 w-full">
        <div class="px-3 py-3 lg:px-5 lg:pl-3">
            <div class="flex items-center justify-between">
                <div class="flex items-center">
                    <button class="lg:hidden mr-2 p-2 rounded hover:bg-gray-100">☰</button>
                    <a href="/" class="flex items-center text-xl font-bold text-gray-800">
                        <img src="https://themewagon.github.io/windster/images/logo.svg" class="h-6 mr-2" alt="Logo">
                        Windster
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <div class="flex overflow-hidden bg-white pt-16">
        <aside id="sidebar"
               class="fixed hidden z-20 h-full top-0 left-0 pt-16 lg:flex flex-shrink-0 flex-col w-72"
               aria-label="Sidebar">
            <div class="relative flex-1 flex flex-col min-h-0 bg-white border-r border-gray-200">
                <div class="flex-1 overflow-y-auto px-4 py-5">

                    <!-- Menü Başlığı -->
                    <div class="mb-4 px-2">
                        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Menü</p>
                    </div>

                    <ul class="space-y-1">

                        <li>
                            <a href="/About/AboutList/"
                               class="group relative flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium
                              text-gray-700 hover:bg-gray-50 hover:text-gray-900 transition">
                                <span class="absolute left-0 top-1/2 -translate-y-1/2 h-7 w-1 rounded-full bg-transparent"></span>
                                <span class="grid place-items-center w-9 h-9 rounded-xl bg-white border border-gray-200 text-gray-500
                                     group-hover:text-cyan-700 group-hover:border-cyan-200 group-hover:bg-cyan-50 transition">
                                    <i class="fa-solid fa-circle-info text-[16px]"></i>
                                </span>
                                <span class="flex-1">Hakkımızda</span>
                                <i class="fa-solid fa-chevron-right text-xs text-gray-300 group-hover:text-gray-400 transition"></i>
                            </a>
                        </li>

                        <li>
                            <a href="/ServiceAI/Index/"
                               class="group relative flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium
                              text-gray-700 hover:bg-gray-50 hover:text-gray-900 transition">
                                <span class="absolute left-0 top-1/2 -translate-y-1/2 h-7 w-1 rounded-full bg-transparent"></span>
                                <span class="grid place-items-center w-9 h-9 rounded-xl bg-white border border-gray-200 text-gray-500
                                     group-hover:text-cyan-700 group-hover:border-cyan-200 group-hover:bg-cyan-50 transition">
                                    <i class="fa-solid fa-layer-group text-[16px]"></i>
                                </span>
                                <span class="flex-1">Hizmetler</span>
                                <i class="fa-solid fa-chevron-right text-xs text-gray-300 group-hover:text-gray-400 transition"></i>
                            </a>
                        </li>

                        <li>
                            <a href="/FAQAI/FAQAIList/"
                               class="group relative flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium
                              text-gray-700 hover:bg-gray-50 hover:text-gray-900 transition">
                                <span class="absolute left-0 top-1/2 -translate-y-1/2 h-7 w-1 rounded-full bg-transparent"></span>
                                <span class="grid place-items-center w-9 h-9 rounded-xl bg-white border border-gray-200 text-gray-500
                                     group-hover:text-cyan-700 group-hover:border-cyan-200 group-hover:bg-cyan-50 transition">
                                    <i class="fa-solid fa-circle-question text-[16px]"></i>
                                </span>
                                <span class="flex-1">FAQ</span>
                                <i class="fa-solid fa-chevron-right text-xs text-gray-300 group-hover:text-gray-400 transition"></i>
                            </a>
                        </li>

                        <li>
                            <a href="/Contact/ContactList/"
                               class="group relative flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium
                              text-gray-700 hover:bg-gray-50 hover:text-gray-900 transition">
                                <span class="absolute left-0 top-1/2 -translate-y-1/2 h-7 w-1 rounded-full bg-transparent"></span>
                                <span class="grid place-items-center w-9 h-9 rounded-xl bg-white border border-gray-200 text-gray-500
                                     group-hover:text-cyan-700 group-hover:border-cyan-200 group-hover:bg-cyan-50 transition">
                                    <i class="fa-solid fa-envelope text-[16px]"></i>
                                </span>
                                <span class="flex-1">İletişim</span>
                                <i class="fa-solid fa-chevron-right text-xs text-gray-300 group-hover:text-gray-400 transition"></i>
                            </a>
                        </li>

                        <li>
                            <a href="/Feature/FeatureList/"
                               class="group relative flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium
                              text-gray-700 hover:bg-gray-50 hover:text-gray-900 transition">
                                <span class="absolute left-0 top-1/2 -translate-y-1/2 h-7 w-1 rounded-full bg-transparent"></span>
                                <span class="grid place-items-center w-9 h-9 rounded-xl bg-white border border-gray-200 text-gray-500
                                     group-hover:text-cyan-700 group-hover:border-cyan-200 group-hover:bg-cyan-50 transition">
                                    <i class="fa-solid fa-star text-[16px]"></i>
                                </span>
                                <span class="flex-1">Öne Çıkanlar</span>
                                <i class="fa-solid fa-chevron-right text-xs text-gray-300 group-hover:text-gray-400 transition"></i>
                            </a>
                        </li>

                        <li>
                            <a href="/OtherFeature/OtherFeatureList/"
                               class="group relative flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium
                              text-gray-700 hover:bg-gray-50 hover:text-gray-900 transition">
                                <span class="absolute left-0 top-1/2 -translate-y-1/2 h-7 w-1 rounded-full bg-transparent"></span>
                                <span class="grid place-items-center w-9 h-9 rounded-xl bg-white border border-gray-200 text-gray-500
                                     group-hover:text-cyan-700 group-hover:border-cyan-200 group-hover:bg-cyan-50 transition">
                                    <i class="fa-solid fa-sliders text-[16px]"></i>
                                </span>
                                <span class="flex-1">Özelliklerimiz</span>
                                <i class="fa-solid fa-chevron-right text-xs text-gray-300 group-hover:text-gray-400 transition"></i>
                            </a>
                        </li>

                        <li>
                            <a href="/Employee/EmployeeList/"
                               class="group relative flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium
                              text-gray-700 hover:bg-gray-50 hover:text-gray-900 transition">
                                <span class="absolute left-0 top-1/2 -translate-y-1/2 h-7 w-1 rounded-full bg-transparent"></span>
                                <span class="grid place-items-center w-9 h-9 rounded-xl bg-white border border-gray-200 text-gray-500
                                     group-hover:text-cyan-700 group-hover:border-cyan-200 group-hover:bg-cyan-50 transition">
                                    <i class="fa-solid fa-users text-[16px]"></i>
                                </span>
                                <span class="flex-1">Ekibimiz</span>
                                <i class="fa-solid fa-chevron-right text-xs text-gray-300 group-hover:text-gray-400 transition"></i>
                            </a>
                        </li>

                        <li>
                            <a href="/Testimonial/TestimonialList/"
                               class="group relative flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium
                              text-gray-700 hover:bg-gray-50 hover:text-gray-900 transition">
                                <span class="absolute left-0 top-1/2 -translate-y-1/2 h-7 w-1 rounded-full bg-transparent"></span>
                                <span class="grid place-items-center w-9 h-9 rounded-xl bg-white border border-gray-200 text-gray-500
                                     group-hover:text-cyan-700 group-hover:border-cyan-200 group-hover:bg-cyan-50 transition">
                                    <i class="fa-solid fa-handshake text-[16px]"></i>
                                </span>
                                <span class="flex-1">Referanslarımız</span>
                                <i class="fa-solid fa-chevron-right text-xs text-gray-300 group-hover:text-gray-400 transition"></i>
                            </a>
                        </li>

                    </ul>

                    <!-- Alt Kısım Kart -->
                    <div class="mt-6 px-2">
                        <div class="rounded-xl border border-gray-200 bg-gray-50 p-3">
                            <p class="text-sm font-semibold text-gray-800">Hızlı erişim</p>
                            <p class="text-xs text-gray-500 mt-1">Ayarlar ve yardım menüsüne buradan ulaş.</p>
                            <a href="#!"
                               class="mt-3 inline-flex items-center text-sm font-medium text-cyan-700 hover:text-cyan-800">
                                <i class="fa-regular fa-circle-question mr-2"></i> Yardım
                            </a>
                        </div>
                    </div>

                </div>
            </div>
        </aside>

        <div id="main-content" class="h-full w-full bg-gray-50 relative overflow-y-auto lg:ml-72">
            <main class="p-6 min-h-[calc(100vh-16rem)]">
                @RenderBody()
            </main>

            <footer class="bg-white md:flex md:items-center md:justify-between shadow rounded-lg p-4 md:p-6 xl:p-8 my-6 mx-4 border border-gray-100">
                <ul class="flex items-center flex-wrap mb-6 md:mb-0">
                    <li><a href="#!" class="text-sm font-normal text-gray-500 hover:underline mr-4 md:mr-6">Terms and conditions</a></li>
                    <li><a href="#!" class="text-sm font-normal text-gray-500 hover:underline mr-4 md:mr-6">Privacy Policy</a></li>
                    <li><a href="#!" class="text-sm font-normal text-gray-500 hover:underline mr-4 md:mr-6">Licensing</a></li>
                    <li><a href="#!" class="text-sm font-normal text-gray-500 hover:underline">Contact</a></li>
                </ul>
                <div class="flex space-x-6 justify-center items-center">
                    <a href="#!" class="text-gray-500 hover:text-blue-600">
                        <i class="fab fa-facebook text-xl"></i>
                    </a>
                    <a href="#!" class="text-gray-500 hover:text-pink-600">
                        <i class="fab fa-instagram text-xl"></i>
                    </a>
                    <a href="#!" class="text-gray-500 hover:text-blue-400">
                        <i class="fab fa-twitter text-xl"></i>
                    </a>
                    <a href="#!" class="text-gray-500 hover:text-gray-900">
                        <i class="fab fa-github text-xl"></i>
                    </a>
                </div>
            </footer>
            <p class="text-center text-sm text-gray-500 pb-10">© 2019-2026 Themesberg. All rights reserved.</p>
        </div>
    </div>
</body>
</html>